{
  "name": "hxm-oshop",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs build",
    "dev": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs dev --host 0.0.0.0",
    "generate": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs generate",
    "preview": "node --max-old-space-size=4096 ./node_modules/nuxt/bin/nuxt.mjs preview",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/db-migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "nuxt": "^4.4.2",
    "postgres": "^3.4.9",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.6.0"
  }
}
